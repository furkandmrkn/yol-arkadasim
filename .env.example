# PostgreSQL (Docker: docker compose up -d)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/travel_navigator?schema=public"

# Google Maps Platform
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="your-google-maps-api-key"
GOOGLE_MAPS_API_KEY="your-google-maps-api-key"

# OpenWeatherMap
OPENWEATHER_API_KEY="your-openweather-api-key"

# OpenAI
OPENAI_API_KEY="your-openai-api-key"

# App URL (for share links)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Auth.js / NextAuth (Google OAuth)
# Generate secret: openssl rand -base64 32
AUTH_SECRET="your-auth-secret"
GOOGLE_CLIENT_ID="your-google-oauth-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-oauth-client-secret"
# Optional locally; required on Vercel production
AUTH_URL="http://localhost:3000"
