generator client {

  provider = "prisma-client-js"

}



datasource db {

  provider = "postgresql"

  url      = env("DATABASE_URL")

}



model User {

  id            String    @id @default(cuid())

  name          String?

  email         String?   @unique

  emailVerified DateTime?

  image         String?

  accounts      Account[]

  sessions      Session[]

  trips         Trip[]

  createdAt     DateTime  @default(now())

  updatedAt     DateTime  @updatedAt

}



model Account {

  userId            String

  type              String

  provider          String

  providerAccountId String

  refresh_token     String? @db.Text

  access_token      String? @db.Text

  expires_at        Int?

  token_type        String?

  scope             String?

  id_token          String? @db.Text

  session_state     String?



  user User @relation(fields: [userId], references: [id], onDelete: Cascade)



  @@id([provider, providerAccountId])

}



model Session {

  sessionToken String   @unique

  userId       String

  expires      DateTime

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

}



model VerificationToken {

  identifier String

  token      String   @unique

  expires    DateTime



  @@id([identifier, token])

}



model Trip {

  id        String     @id @default(cuid())

  createdAt DateTime   @default(now())

  updatedAt DateTime   @updatedAt

  status    TripStatus @default(DRAFT)

  planType  PlanType   @default(TRIP)



  userId     String?

  guestToken String?

  user       User?   @relation(fields: [userId], references: [id], onDelete: SetNull)



  origin      String

  destination String

  originLat   Float?

  originLng   Float?

  destLat     Float?

  destLng     Float?

  startDate   DateTime

  endDate     DateTime

  days        Int



  adults       Int     @default(1)

  childrenAges Int[]   @default([])

  hasBaby      Boolean @default(false)



  transport       TransportMode @default(CAR)

  budget          BudgetLevel   @default(MID)

  pace            PaceLevel     @default(MODERATE)

  foodPreferences String[]      @default([])



  exploreMode      Boolean           @default(false)

  exploreIntensity ExploreIntensity?

  categories       String[]          @default([])

  localVsTourist   Int               @default(50)



  lodgingNeeded     Boolean      @default(false)

  lodgingBreakfast  Boolean      @default(false)

  lodgingType       LodgingType?

  lodgingPriceRange PriceRange?



  weatherSummary Json?

  routeSummary   Json?



  stops TripStop[]



  @@index([userId])

  @@index([guestToken])

}



model TripStop {

  id     String @id @default(cuid())

  tripId String

  trip   Trip   @relation(fields: [tripId], references: [id], onDelete: Cascade)



  placeId String?

  name    String

  lat     Float

  lng     Float

  address String?

  category String?

  stopType StopType @default(POI)



  day             Int @default(1)

  sortOrder       Int @default(0)

  durationMinutes Int @default(60)



  rating      Float?

  reviewCount Int?

  photoUrl    String?

  reason      String?

  evidence    Json?

  weatherTag  String?



  selected Boolean @default(true)



  @@index([tripId])

}



enum TripStatus {

  DRAFT

  PLANNED

  COMPLETED

}



enum PlanType {

  TRIP

  CITY_DAY

}



enum TransportMode {

  CAR

  TRANSIT

  WALK

}



enum BudgetLevel {

  BUDGET

  MID

  LUXURY

}



enum PaceLevel {

  RELAXED

  MODERATE

  PACKED

}



enum ExploreIntensity {

  LOW

  MEDIUM

  HIGH

}



enum LodgingType {

  HOTEL

  PENSION

  APART

  ANY

}



enum PriceRange {

  LOW

  MID

  HIGH

}



enum StopType {

  POI

  LODGING

  FOOD

  ORIGIN

  DESTINATION

}


